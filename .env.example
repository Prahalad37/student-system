# Copy this file to .env and set real values. Do not commit .env.

# Required in production. Use a long random string.
DJANGO_SECRET_KEY=your-secret-key-here

# Set to true only for local development. Must be False in production.
DEBUG=False

# Optional: override Django settings module (default is mysite.settings).
# DJANGO_SETTINGS_MODULE=mysite.settings

# Optional: comma-separated allowed hosts (production domain, etc.).
# ALLOWED_HOST=prahalad.pythonanywhere.com,prahaladpal.pythonanywhere.com

# Optional: database URL for PostgreSQL (e.g. on Render/Heroku).
# DATABASE_URL=postgresql://user:password@host:5432/dbname
